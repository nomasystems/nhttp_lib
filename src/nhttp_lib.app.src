{application, nhttp_lib, [
    {description, "HTTP protocol primitives for Erlang/OTP 27+ (HTTP/1.1, HTTP/2, HTTP/3, QPACK)"},
    {vsn, "1.0.2"},
    {registered, []},
    {applications, [
        kernel,
        stdlib,
        ssl,
        crypto,
        public_key,
        nquic
    ]},
    {env, []},
    {modules, []},
    {licenses, ["Apache-2.0"]},
    {links, [{"GitHub", "https://github.com/nomasystems/nhttp_lib"}]}
]}.
